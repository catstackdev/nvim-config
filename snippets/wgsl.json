{
  "fn": {
    "prefix": "fn",
    "body": "fn ${1:name}(${2:params}) -> ${3:f32} {\n\t$0\n}",
    "description": "Function declaration"
  },
  "fn void": {
    "prefix": "fnv",
    "body": "fn ${1:name}(${2:params}) {\n\t$0\n}",
    "description": "Function declaration (no return)"
  },
  "struct": {
    "prefix": "struct",
    "body": "struct ${1:Name} {\n\t${2:field}: ${3:f32},$0\n}",
    "description": "Struct declaration"
  },
  "const": {
    "prefix": "const",
    "body": "const ${1:NAME}: ${2:f32} = ${3:0.0};$0",
    "description": "Module-level constant"
  },
  "let": {
    "prefix": "let",
    "body": "let ${1:name} = ${2:value};$0",
    "description": "Immutable local binding"
  },
  "var": {
    "prefix": "var",
    "body": "var ${1:name} = ${2:value};$0",
    "description": "Mutable local variable"
  },
  "alias": {
    "prefix": "alias",
    "body": "alias ${1:Name} = ${2:f32};$0",
    "description": "Type alias"
  },
  "override": {
    "prefix": "override",
    "body": "override ${1:name}: ${2:f32} = ${3:0.0};$0",
    "description": "Pipeline-overridable constant"
  },

  "var uniform": {
    "prefix": "var<uniform>",
    "body": "@group(${1:0}) @binding(${2:0}) var<uniform> ${3:name}: ${4:Uniforms};$0",
    "description": "Uniform buffer binding"
  },
  "var storage": {
    "prefix": "var<storage>",
    "body": "@group(${1:0}) @binding(${2:0}) var<storage, ${3:read}> ${4:name}: ${5:array<f32>};$0",
    "description": "Storage buffer binding (read / read_write)"
  },
  "var workgroup": {
    "prefix": "var<workgroup>",
    "body": "var<workgroup> ${1:name}: ${2:array<f32, 64>};$0",
    "description": "Workgroup-shared variable"
  },
  "var private": {
    "prefix": "var<private>",
    "body": "var<private> ${1:name}: ${2:f32} = ${3:0.0};$0",
    "description": "Module-private mutable"
  },

  "@vertex": {
    "prefix": "@vertex",
    "body": "@vertex\nfn ${1:vs_main}(${2:@location(0) position: vec3<f32>}) -> @builtin(position) vec4<f32> {\n\treturn vec4<f32>(${3:position}, 1.0);$0\n}",
    "description": "Vertex entry point"
  },
  "@fragment": {
    "prefix": "@fragment",
    "body": "@fragment\nfn ${1:fs_main}(${2:@location(0) uv: vec2<f32>}) -> @location(0) vec4<f32> {\n\t$0\n\treturn vec4<f32>(1.0);\n}",
    "description": "Fragment entry point"
  },
  "@compute": {
    "prefix": "@compute",
    "body": "@compute @workgroup_size(${1:8}, ${2:8}, ${3:1})\nfn ${4:cs_main}(@builtin(global_invocation_id) gid: vec3<u32>) {\n\t$0\n}",
    "description": "Compute entry point"
  },

  "@group": {
    "prefix": "@group",
    "body": "@group(${1:0}) @binding(${2:0})$0",
    "description": "Resource binding attribute"
  },
  "@binding": {
    "prefix": "@binding",
    "body": "@binding(${1:0})$0",
    "description": "Binding index attribute"
  },
  "@location": {
    "prefix": "@location",
    "body": "@location(${1:0})$0",
    "description": "I/O location attribute"
  },
  "@builtin": {
    "prefix": "@builtin",
    "body": "@builtin(${1|position,vertex_index,instance_index,front_facing,frag_depth,sample_index,sample_mask,local_invocation_id,local_invocation_index,global_invocation_id,workgroup_id,num_workgroups|})$0",
    "description": "Built-in I/O attribute"
  },
  "@workgroup_size": {
    "prefix": "@workgroup_size",
    "body": "@workgroup_size(${1:8}, ${2:8}, ${3:1})$0",
    "description": "Compute workgroup dimensions"
  },
  "@interpolate": {
    "prefix": "@interpolate",
    "body": "@interpolate(${1|perspective,linear,flat|}, ${2|center,centroid,sample|})$0",
    "description": "Interpolation attribute"
  },

  "if": {
    "prefix": "if",
    "body": "if (${1:condition}) {\n\t$0\n}",
    "description": "if statement"
  },
  "if else": {
    "prefix": "ife",
    "body": "if (${1:condition}) {\n\t$2\n} else {\n\t$0\n}",
    "description": "if/else statement"
  },
  "for": {
    "prefix": "for",
    "body": "for (var ${1:i} = ${2:0}; ${1:i} < ${3:n}; ${1:i}++) {\n\t$0\n}",
    "description": "for loop"
  },
  "while": {
    "prefix": "while",
    "body": "while (${1:condition}) {\n\t$0\n}",
    "description": "while loop"
  },
  "loop": {
    "prefix": "loop",
    "body": "loop {\n\t$1\n\tif (${2:condition}) { break; }\n\t$0\n}",
    "description": "Infinite loop"
  },
  "switch": {
    "prefix": "switch",
    "body": "switch (${1:value}) {\n\tcase ${2:0}: {\n\t\t$3\n\t}\n\tdefault: {\n\t\t$0\n\t}\n}",
    "description": "switch statement"
  },
  "return": {
    "prefix": "return",
    "body": "return ${1:value};$0",
    "description": "return statement"
  },

  "f32": {
    "prefix": "f32",
    "body": "f32",
    "description": "32-bit float"
  },
  "f16": {
    "prefix": "f16",
    "body": "f16",
    "description": "16-bit float (requires 'f16' extension)"
  },
  "i32": {
    "prefix": "i32",
    "body": "i32",
    "description": "32-bit signed integer"
  },
  "u32": {
    "prefix": "u32",
    "body": "u32",
    "description": "32-bit unsigned integer"
  },
  "bool": {
    "prefix": "bool",
    "body": "bool",
    "description": "Boolean (true / false)"
  },

  "vec2f": {
    "prefix": "vec2f",
    "body": "vec2f",
    "description": "alias for vec2<f32>"
  },
  "vec3f": {
    "prefix": "vec3f",
    "body": "vec3f",
    "description": "alias for vec3<f32>"
  },
  "vec4f": {
    "prefix": "vec4f",
    "body": "vec4f",
    "description": "alias for vec4<f32>"
  },
  "vec2i": {
    "prefix": "vec2i",
    "body": "vec2i",
    "description": "alias for vec2<i32>"
  },
  "vec3i": {
    "prefix": "vec3i",
    "body": "vec3i",
    "description": "alias for vec3<i32>"
  },
  "vec4i": {
    "prefix": "vec4i",
    "body": "vec4i",
    "description": "alias for vec4<i32>"
  },
  "vec2u": {
    "prefix": "vec2u",
    "body": "vec2u",
    "description": "alias for vec2<u32>"
  },
  "vec3u": {
    "prefix": "vec3u",
    "body": "vec3u",
    "description": "alias for vec3<u32>"
  },
  "vec4u": {
    "prefix": "vec4u",
    "body": "vec4u",
    "description": "alias for vec4<u32>"
  },

  "mat2x2f": {
    "prefix": "mat2x2f",
    "body": "mat2x2f",
    "description": "alias for mat2x2<f32>"
  },
  "mat3x3f": {
    "prefix": "mat3x3f",
    "body": "mat3x3f",
    "description": "alias for mat3x3<f32>"
  },
  "mat4x4f": {
    "prefix": "mat4x4f",
    "body": "mat4x4f",
    "description": "alias for mat4x4<f32>"
  },
  "mat2x3f": {
    "prefix": "mat2x3f",
    "body": "mat2x3f",
    "description": "alias for mat2x3<f32>"
  },
  "mat3x2f": {
    "prefix": "mat3x2f",
    "body": "mat3x2f",
    "description": "alias for mat3x2<f32>"
  },
  "mat2x4f": {
    "prefix": "mat2x4f",
    "body": "mat2x4f",
    "description": "alias for mat2x4<f32>"
  },
  "mat4x2f": {
    "prefix": "mat4x2f",
    "body": "mat4x2f",
    "description": "alias for mat4x2<f32>"
  },
  "mat3x4f": {
    "prefix": "mat3x4f",
    "body": "mat3x4f",
    "description": "alias for mat3x4<f32>"
  },
  "mat4x3f": {
    "prefix": "mat4x3f",
    "body": "mat4x3f",
    "description": "alias for mat4x3<f32>"
  },

  "vec2": {
    "prefix": "vec2",
    "body": "vec2<${1|f32,i32,u32|}>(${2:0.0})$0",
    "description": "2-component vector"
  },
  "vec3": {
    "prefix": "vec3",
    "body": "vec3<${1|f32,i32,u32|}>(${2:0.0})$0",
    "description": "3-component vector"
  },
  "vec4": {
    "prefix": "vec4",
    "body": "vec4<${1|f32,i32,u32|}>(${2:0.0})$0",
    "description": "4-component vector"
  },
  "mat3x3": {
    "prefix": "mat3x3",
    "body": "mat3x3<f32>($0)",
    "description": "3x3 matrix"
  },
  "mat4x4": {
    "prefix": "mat4x4",
    "body": "mat4x4<f32>($0)",
    "description": "4x4 matrix"
  },
  "array": {
    "prefix": "array",
    "body": "array<${1:f32}, ${2:N}>$0",
    "description": "Fixed-size array type"
  },
  "ptr": {
    "prefix": "ptr",
    "body": "ptr<${1|function,private,workgroup,uniform,storage|}, ${2:f32}>$0",
    "description": "Pointer type"
  },

  "texture_2d": {
    "prefix": "texture_2d",
    "body": "@group(${1:0}) @binding(${2:0}) var ${3:tex}: texture_2d<${4|f32,i32,u32|}>;$0",
    "description": "2D texture binding"
  },
  "texture_storage_2d": {
    "prefix": "texture_storage_2d",
    "body": "@group(${1:0}) @binding(${2:0}) var ${3:tex}: texture_storage_2d<${4:rgba8unorm}, ${5|read,write,read_write|}>;$0",
    "description": "Storage texture binding"
  },
  "sampler": {
    "prefix": "sampler",
    "body": "@group(${1:0}) @binding(${2:0}) var ${3:samp}: sampler;$0",
    "description": "Sampler binding"
  },

  "textureSample": {
    "prefix": "textureSample",
    "body": "textureSample(${1:tex}, ${2:samp}, ${3:uv})$0",
    "description": "Sample a texture"
  },
  "textureLoad": {
    "prefix": "textureLoad",
    "body": "textureLoad(${1:tex}, ${2:coord}, ${3:0})$0",
    "description": "Load a texel without sampling"
  },
  "textureStore": {
    "prefix": "textureStore",
    "body": "textureStore(${1:tex}, ${2:coord}, ${3:value});$0",
    "description": "Write a texel to a storage texture"
  },

  "uniforms struct": {
    "prefix": "Uniforms",
    "body": "struct Uniforms {\n\t${1:view_proj}: mat4x4<f32>,\n\t${2:time}: f32,$0\n}\n\n@group(0) @binding(0) var<uniform> u: Uniforms;",
    "description": "Uniforms struct + binding"
  },
  "vs+fs scaffold": {
    "prefix": "shader",
    "body": "struct VsOut {\n\t@builtin(position) position: vec4<f32>,\n\t@location(0) uv: vec2<f32>,\n}\n\n@vertex\nfn vs_main(@location(0) pos: vec3<f32>, @location(1) uv: vec2<f32>) -> VsOut {\n\tvar out: VsOut;\n\tout.position = vec4<f32>(pos, 1.0);\n\tout.uv = uv;\n\treturn out;\n}\n\n@fragment\nfn fs_main(in: VsOut) -> @location(0) vec4<f32> {\n\t$0\n\treturn vec4<f32>(in.uv, 0.0, 1.0);\n}",
    "description": "Vertex + fragment scaffold"
  }
}
